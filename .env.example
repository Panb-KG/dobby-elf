# ============================================
# Zeabur 部署环境变量配置
# ============================================

# JWT 密钥（⚠️ 生产环境必须修改！）
# 用于用户认证令牌签名，必须至少 16 位
# 生成方法：openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_KEY_MIN_16_CHARS

# 应用 URL（Zeabur 会自动注入）
APP_URL=https://your-app-name.zeabur.app

# Alibaba Cloud Token Plan / DashScope API Key
# 主配置: Token Plan (北京)
TOKEN_PLAN_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TOKEN_PLAN_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

# 备选: Coding Plan (百炼)
DASHSCOPE_API_KEY=sk-sp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# ============================================
# 可选配置
# ============================================

# Node 环境（Zeabur 会自动设置为 production）
NODE_ENV=production

# 端口（Zeabur 会自动注入）
PORT=3000

# 禁用 Next.js 遥测
NEXT_TELEMETRY_DISABLED=1
