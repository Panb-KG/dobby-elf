# ============================================
# Zeabur 部署环境变量配置
# ============================================

# JWT 密钥（生产环境必须修改为强随机字符串）
# 用于用户认证令牌签名，建议使用 32 位以上随机字符串
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 应用 URL（Zeabur 会自动注入）
APP_URL=https://your-app-name.zeabur.app

# Alibaba Cloud Bailian (DashScope) API Key
# 获取方式: https://bailian.console.aliyun.com/cn-beijing?tab=model#/api-key
# 华北2（北京）地域: https://dashscope.aliyuncs.com/compatible-mode/v1
# 新加坡地域: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# 美国（弗吉尼亚）: https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================
# 可选配置
# ============================================

# Node 环境（Zeabur 会自动设置为 production）
NODE_ENV=production

# 端口（Zeabur 会自动注入）
PORT=3000

# 禁用 Next.js 遥测
NEXT_TELEMETRY_DISABLED=1
