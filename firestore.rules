rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - points: number (required)
    //   - preferences: map (optional)
    //   - displayName: string (optional)
    //   - email: string (optional)
    //
    // Collection: users/{userId}/courses
    // Document ID: auto-generated
    // Fields:
    //   - day: string (required, enum)
    //   - subject: string (required, max 100 chars)
    //   - time: string (required, format HH:MM - HH:MM)
    //   - type: string (required, enum: 校内, 课外)
    //   - color: string (required)
    //   - uid: string (required, matches owner)
    //
    // Collection: users/{userId}/achievements
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - date: string (required)
    //   - type: string (required)
    //   - iconName: string (required)
    //   - color: string (required)
    //   - uid: string (required, matches owner)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "paulpan99@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['points', 'level', 'treeGrowth', 'dailyTasks', 'outfit', 'preferences', 'displayName', 'email', 'role']) &&
             data.points is int && data.points >= 0;
    }

    function isValidCourse(data) {
      return hasRequiredFields(['day', 'subject', 'time', 'type', 'color', 'uid']) &&
             data.day in ['周一', '周二', '周三', '周四', '周五', '周六', '周日'] &&
             data.type in ['校内', '课外'] &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() < 100 &&
             data.uid == request.auth.uid;
    }

    function isValidAchievement(data) {
      return hasRequiredFields(['title', 'date', 'type', 'iconName', 'color', 'uid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());

      match /courses/{courseId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidCourse(request.resource.data);
        allow update: if isOwner(userId) && isValidCourse(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /achievements/{achievementId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidAchievement(request.resource.data);
        allow update: if isOwner(userId) && isValidAchievement(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
