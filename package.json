{
  "name": "dobi-elf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js -p ${PORT:-3000}",
    "lint": "next lint",
    "test": "vitest run",
    "migrate": "npx tsx scripts/migrate.ts",
    "migrate:status": "npx tsx scripts/migrate.ts --status",
    "migrate:reset": "npx tsx scripts/migrate.ts --reset",
    "postinstall": "echo 'Skipping native module rebuild - using Supabase instead'",
    "healthcheck": "node -e \"require('http').get('http://localhost:'+(process.env.PORT||3000)+'/api/health', (r) => {process.exit(r.statusCode===200?0:1)}).on('error', () => process.exit(1))\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/postcss": "^4.2.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vitest": "^3.1.3"
  }
}
